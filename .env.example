# Email Manager — VPS .env file
# Copy this to .env on the server and fill in the values.

# ── Database ──────────────────────────────────────────
DB_USERNAME=email_manager
DB_PASSWORD=your_strong_db_password

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=your_256bit_jwt_secret_here

# ── AES Encryption (for IMAP passwords) ───────────────
ENCRYPTION_KEY=your_32_character_aes_key_here!!

# ── App Account (seeded on first boot) ────────────────
APP_USERNAME=Andy
APP_PASSWORD=admin123

# ── CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://api.facturo.it.com
